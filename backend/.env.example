# Application Environment Variables
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

# Application
DEBUG=false
API_PREFIX=/api/v1

# Database
POSTGRES_USER=godeyes
POSTGRES_PASSWORD=godeyes_secure_password_2024
POSTGRES_DB=godeyes
DATABASE_URL=postgresql://godeyes:godeyes_secure_password_2024@postgres:5432/godeyes

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT Authentication
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Mapbox API
# Get your tokens at https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=
MAPBOX_SECRET_TOKEN=

# Sentinel Hub (ESA Copernicus)
# Create free account at https://www.sentinel-hub.com/
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# OpenWeatherMap (for weather overlay and live cameras)
# Get free API key at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# CORS Origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# File Upload
MAX_UPLOAD_SIZE_MB=500

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
